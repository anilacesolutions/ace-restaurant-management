HTTP_ADDR=:8080
APP_ENV=dev

# MongoDB — connection string provided by user; do not commit a real one
MONGO_URI=mongodb://localhost:27017
MONGO_DB=restaurant

# Single-tenant MVP — restaurant ID returned by `go run ./cmd/seed`
DEFAULT_RESTAURANT_ID=

# CORS — comma-separated origins allowed to call the API.
# Prod: set to the app origin, e.g. https://kasa.gunguzelbahce.online
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cookie domain — leave EMPTY in dev (host-only cookie). In prod set to the
# parent domain with a leading dot so the app + API subdomains share the
# session cookie (required for SSR auth): COOKIE_DOMAIN=.gunguzelbahce.online
COOKIE_DOMAIN=

# MQTT — AWS IoT Core endpoint in prod, mosquitto for local dev
# Local dev example: tcp://localhost:1883
# AWS IoT Core example: tls://xxx-ats.iot.eu-west-1.amazonaws.com:8883
MQTT_BROKER=
MQTT_CLIENT_ID=restaurant-backend
MQTT_USERNAME=
MQTT_PASSWORD=

# S3 — menu item images. Leave S3_BUCKET empty to disable image upload
# (the rest of the menu still works; the presign endpoint returns 501).
# Credentials come from the default AWS chain (env / ~/.aws / IAM role).
# S3_PUBLIC_BASE_URL is optional: set it to a CloudFront domain in front of
# the bucket, otherwise object URLs are derived from bucket+region.
S3_BUCKET=
AWS_REGION=eu-west-1
S3_PUBLIC_BASE_URL=
