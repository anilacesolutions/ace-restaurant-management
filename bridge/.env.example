# Each bridge serves one restaurant
RESTAURANT_ID=

# Broker — same one the backend uses
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=restaurant-bridge
MQTT_USERNAME=
MQTT_PASSWORD=

# Printer — start with stdout in dev, switch to network or usb in prod
# stdout: writes formatted ticket to stdout (good for dev / docker logs)
# network: ESC/POS over TCP, addr like 192.168.1.50:9100
# usb: raw device, addr like /dev/usb/lp0 (Linux)
PRINTER_MODE=stdout
PRINTER_ADDR=
PRINTER_COLS=42
