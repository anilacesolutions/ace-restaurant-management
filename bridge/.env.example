# Each bridge serves one restaurant
RESTAURANT_ID=
# Printed as the adisyon header (upper-case ASCII)
RESTAURANT_NAME=GUN GUZELBAHCE

# Broker — same one the backend uses
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=restaurant-bridge
MQTT_USERNAME=
MQTT_PASSWORD=

# Printer
# stdout : writes the ticket to stdout (dev / logs)
# windows: RAW ESC/POS via the Windows spooler — PRINTER_ADDR = the printer's
#          exact Windows name (Settings > Printers). Use this on the register PC.
# network: ESC/POS over TCP, PRINTER_ADDR like 192.168.1.50:9100
# usb    : raw device (Linux only), PRINTER_ADDR like /dev/usb/lp0
PRINTER_MODE=stdout
PRINTER_ADDR=
# characters per line: 58mm = 32, 80mm = 48
PRINTER_COLS=32
