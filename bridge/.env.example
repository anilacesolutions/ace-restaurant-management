# Each bridge serves one restaurant
RESTAURANT_ID=
# Printed as the adisyon header (upper-case ASCII)
RESTAURANT_NAME=GUN GUZELBAHCE

# Broker — same one the backend uses
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=restaurant-bridge
MQTT_USERNAME=
MQTT_PASSWORD=

# Printer transport (shared by both printers)
# stdout : writes tickets to stdout (dev / logs)
# windows: RAW ESC/POS via the Windows spooler — addresses below are the exact
#          Windows printer names (Settings > Printers). Use this on the register PC.
# network: ESC/POS over TCP, address like 192.168.1.50:9100
# usb    : raw device (Linux only), address like /dev/usb/lp0
PRINTER_MODE=stdout

# Two printers, split by role. Kitchen ticket (Mutfağa Gönder) and customer
# adisyon (Adisyon Bas) can be different physical printers / paper widths.
# characters per line: 58mm = 32, 80mm = 48
KITCHEN_PRINTER_ADDR=
KITCHEN_PRINTER_COLS=32
ADISYON_PRINTER_ADDR=
ADISYON_PRINTER_COLS=48

# Single-printer fallback: if the two ADDR vars above are empty, both roles use
# these instead.
PRINTER_ADDR=
PRINTER_COLS=32
